{
  "version": 1,
  "id": "guard",
  "rootId": "root",
  "blackboard": [
    { "key": "patrol",      "type": "bool", "default": true },
    { "key": "target_seen", "type": "bool", "default": false }
  ],
  "nodes": {
    "root": {
      "type": "Selector",
      "label": "Guard AI",
      "children": ["sel_combat", "leaf_uncrouch", "leaf_chase", "seq_patrol", "leaf_stand"],
      "props": {}
    },

    "sel_combat": {
      "type": "Selector",
      "label": "Combat",
      "children": ["leaf_look0", "leaf_look1", "leaf_look2", "leaf_look3", "leaf_look4", "leaf_look5"],
      "props": {}
    },
    "leaf_look0": { "type": "Leaf", "label": "Look(0) forward",    "children": [], "props": { "action": "Look0" } },
    "leaf_look1": { "type": "Leaf", "label": "Look(1) low forward","children": [], "props": { "action": "Look1" } },
    "leaf_look2": { "type": "Leaf", "label": "Look(2) up",         "children": [], "props": { "action": "Look2" } },
    "leaf_look3": { "type": "Leaf", "label": "Look(3) down",       "children": [], "props": { "action": "Look3" } },
    "leaf_look4": { "type": "Leaf", "label": "Look(4) up-angle",   "children": [], "props": { "action": "Look4" } },
    "leaf_look5": { "type": "Leaf", "label": "Look(5) down-angle", "children": [], "props": { "action": "Look5" } },

    "leaf_uncrouch": { "type": "Leaf", "label": "Uncrouch if idle", "children": [], "props": { "action": "UncrouchIdle" } },
    "leaf_chase":    { "type": "Leaf", "label": "Chase target",     "children": [], "props": { "action": "Chase"        } },

    "seq_patrol": {
      "type": "Sequence",
      "label": "Patrol",
      "children": ["cond_patrol", "leaf_patrol"],
      "props": {}
    },
    "cond_patrol": { "type": "Condition", "label": "patrol?",    "children": [], "props": { "key": "patrol", "value": true } },
    "leaf_patrol": { "type": "Leaf",      "label": "Patrol walk","children": [], "props": { "action": "Patrol" } },

    "leaf_stand": { "type": "Leaf", "label": "Stand", "children": [], "props": { "action": "Stand" } }
  },
  "positions": {}
}
