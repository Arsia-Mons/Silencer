{
  "version": 1,
  "id": "guard-patrol",
  "blackboard": [
    { "key": "player_visible",       "type": "bool",  "default": false },
    { "key": "player_crouched_shot", "type": "bool",  "default": false },
    { "key": "player_above",         "type": "bool",  "default": false },
    { "key": "player_below",         "type": "bool",  "default": false },
    { "key": "player_above_angle",   "type": "bool",  "default": false },
    { "key": "player_below_angle",   "type": "bool",  "default": false },
    { "key": "any_target",           "type": "bool",  "default": false },
    { "key": "cooled_down",          "type": "bool",  "default": false },
    { "key": "crouched",             "type": "bool",  "default": false },
    { "key": "patrol",               "type": "bool",  "default": true  },
    { "key": "health_pct",           "type": "float", "default": 1.0   }
  ],
  "rootId": "root",
  "nodes": {
    "root": {
      "type": "Selector",
      "label": "Guard AI",
      "children": [
        "seq_shoot_standing",
        "seq_crouch_then_shoot",
        "seq_shoot_crouched",
        "seq_uncrouch",
        "seq_shoot_up",
        "seq_shoot_down",
        "seq_shoot_up_angle",
        "seq_shoot_down_angle",
        "idle_look",
        "seq_patrol",
        "leaf_stand"
      ],
      "props": {}
    },

    "seq_shoot_standing": {
      "type": "Sequence",
      "label": "Shoot Standing",
      "children": ["cond_visible_1", "cond_cd_1", "leaf_shoot_standing"],
      "props": {}
    },
    "cond_visible_1":   { "type": "Condition", "label": "player_visible?",  "children": [], "props": { "key": "player_visible",   "value": true } },
    "cond_cd_1":        { "type": "Condition", "label": "cooled_down?",     "children": [], "props": { "key": "cooled_down",      "value": true } },
    "leaf_shoot_standing": { "type": "Leaf", "label": "ShootStanding", "children": [], "props": { "action": "ShootStanding" } },

    "seq_crouch_then_shoot": {
      "type": "Sequence",
      "label": "Crouch (target crouched)",
      "children": ["cond_crouched_ray_1", "cond_not_crouched_1", "leaf_crouch"],
      "props": {}
    },
    "cond_crouched_ray_1": { "type": "Condition", "label": "player_crouched_shot?", "children": [], "props": { "key": "player_crouched_shot", "value": true } },
    "cond_not_crouched_1": { "type": "Inverter", "label": "NOT crouched",           "children": ["cond_crouched_1"], "props": {} },
    "cond_crouched_1":     { "type": "Condition", "label": "crouched?",             "children": [], "props": { "key": "crouched", "value": true } },
    "leaf_crouch":         { "type": "Leaf", "label": "Crouch",                     "children": [], "props": { "action": "Crouch" } },

    "seq_shoot_crouched": {
      "type": "Sequence",
      "label": "Shoot Crouched",
      "children": ["cond_crouched_ray_2", "cond_crouched_2", "cond_cd_2", "leaf_shoot_crouched"],
      "props": {}
    },
    "cond_crouched_ray_2": { "type": "Condition", "label": "player_crouched_shot?", "children": [], "props": { "key": "player_crouched_shot", "value": true } },
    "cond_crouched_2":     { "type": "Condition", "label": "crouched?",             "children": [], "props": { "key": "crouched",             "value": true } },
    "cond_cd_2":           { "type": "Condition", "label": "cooled_down?",          "children": [], "props": { "key": "cooled_down",          "value": true } },
    "leaf_shoot_crouched": { "type": "Leaf", "label": "ShootCrouched",              "children": [], "props": { "action": "ShootCrouched" } },

    "seq_uncrouch": {
      "type": "Sequence",
      "label": "Uncrouch (no target)",
      "children": ["cond_no_target", "cond_crouched_3", "leaf_uncrouch"],
      "props": {}
    },
    "cond_no_target":  { "type": "Inverter", "label": "NOT any_target", "children": ["cond_any_target"], "props": {} },
    "cond_any_target": { "type": "Condition", "label": "any_target?",  "children": [], "props": { "key": "any_target", "value": true } },
    "cond_crouched_3": { "type": "Condition", "label": "crouched?",    "children": [], "props": { "key": "crouched",   "value": true } },
    "leaf_uncrouch":   { "type": "Leaf", "label": "Uncrouch",          "children": [], "props": { "action": "Uncrouch" } },

    "seq_shoot_up": {
      "type": "Sequence",
      "label": "Shoot Up",
      "children": ["cond_above_1", "cond_cd_3", "leaf_shoot_up"],
      "props": {}
    },
    "cond_above_1":  { "type": "Condition", "label": "player_above?", "children": [], "props": { "key": "player_above", "value": true } },
    "cond_cd_3":     { "type": "Condition", "label": "cooled_down?",  "children": [], "props": { "key": "cooled_down",  "value": true } },
    "leaf_shoot_up": { "type": "Leaf", "label": "ShootUp",            "children": [], "props": { "action": "ShootUp" } },

    "seq_shoot_down": {
      "type": "Sequence",
      "label": "Shoot Down",
      "children": ["cond_below_1", "cond_cd_4", "leaf_shoot_down"],
      "props": {}
    },
    "cond_below_1":    { "type": "Condition", "label": "player_below?", "children": [], "props": { "key": "player_below", "value": true } },
    "cond_cd_4":       { "type": "Condition", "label": "cooled_down?",  "children": [], "props": { "key": "cooled_down",  "value": true } },
    "leaf_shoot_down": { "type": "Leaf", "label": "ShootDown",          "children": [], "props": { "action": "ShootDown" } },

    "seq_shoot_up_angle": {
      "type": "Sequence",
      "label": "Shoot Up Angle",
      "children": ["cond_above_angle_1", "cond_cd_5", "leaf_shoot_up_angle"],
      "props": {}
    },
    "cond_above_angle_1":  { "type": "Condition", "label": "player_above_angle?", "children": [], "props": { "key": "player_above_angle", "value": true } },
    "cond_cd_5":           { "type": "Condition", "label": "cooled_down?",        "children": [], "props": { "key": "cooled_down",        "value": true } },
    "leaf_shoot_up_angle": { "type": "Leaf", "label": "ShootUpAngle",             "children": [], "props": { "action": "ShootUpAngle" } },

    "seq_shoot_down_angle": {
      "type": "Sequence",
      "label": "Shoot Down Angle",
      "children": ["cond_below_angle_1", "cond_cd_6", "leaf_shoot_down_angle"],
      "props": {}
    },
    "cond_below_angle_1":  { "type": "Condition", "label": "player_below_angle?", "children": [], "props": { "key": "player_below_angle", "value": true } },
    "cond_cd_6":           { "type": "Condition", "label": "cooled_down?",        "children": [], "props": { "key": "cooled_down",        "value": true } },
    "leaf_shoot_down_angle": { "type": "Leaf", "label": "ShootDownAngle",         "children": [], "props": { "action": "ShootDownAngle" } },

    "idle_look": {
      "type": "Cooldown",
      "label": "Look (3s cd)",
      "children": ["leaf_look"],
      "props": { "duration": 3.0 }
    },
    "leaf_look": { "type": "Leaf", "label": "Look", "children": [], "props": { "action": "Look" } },

    "seq_patrol": {
      "type": "Sequence",
      "label": "Patrol",
      "children": ["cond_patrol", "leaf_patrol"],
      "props": {}
    },
    "cond_patrol":  { "type": "Condition", "label": "patrol?", "children": [], "props": { "key": "patrol", "value": true } },
    "leaf_patrol":  { "type": "Leaf", "label": "Patrol",       "children": [], "props": { "action": "Patrol" } },

    "leaf_stand": { "type": "Leaf", "label": "Stand", "children": [], "props": { "action": "Stand" } }
  },
  "positions": {}
}

